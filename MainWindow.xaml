<Window x:Class="Digitron.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DIGITRON" Height="350" Width="460"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="14"
        Background="#F7F7FB">

 
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F46E5"/>
    
        <SolidColorBrush x:Key="AccentBrushLight" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="LineBrush" Color="#E5E7EB"/>

   
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource AccentBrush}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#6366F1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4338CA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

   
        <Style x:Key="LightButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{StaticResource AccentBrushLight}" CornerRadius="10" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E0E7FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C7D2FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>
     
            <RowDefinition Height="Auto"/>
     
            <RowDefinition Height="*"/>
       
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AccentBrushLight}" Padding="10" CornerRadius="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🧮" FontSize="20" Margin="0,0,6,0"/>
                <TextBlock Text="DIGITRON" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Width="182" RenderTransformOrigin="0.487,0.613"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="A" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtA" Grid.Column="1"/>

            <TextBlock Grid.Column="2"/>

            <TextBlock Grid.Column="3" Text="B" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtB" Grid.Column="4" TextChanged="txtB_TextChanged"/>
        </Grid>

        <UniformGrid Grid.Row="2" Columns="5" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="btnSabiranje"  Content="+"  Style="{StaticResource AccentButton}" Click="btnSabiranje_Click"/>
            <Button x:Name="btnOduzimanje" Content="−"  Style="{StaticResource AccentButton}" Click="btnOduzimanje_Click"/>
            <Button x:Name="btnMnozenje"   Content="×"  Style="{StaticResource AccentButton}" Click="btnMnozenje_Click"/>
            <Button x:Name="btnDeljenje"   Content="÷"  Style="{StaticResource AccentButton}" Click="btnDeljenje_Click"/>
            <Button x:Name="btnOcisti"     Content="⟲"  Style="{StaticResource LightButton}"  ToolTip="Očisti" Click="btnOcisti_Click"/>
        </UniformGrid>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Rezultat" FontWeight="SemiBold"/>
            <TextBox x:Name="txtRezultat" Height="42" Margin="0,6,0,0" IsReadOnly="True" FontSize="18" VerticalContentAlignment="Center"/>
            <TextBlock x:Name="txtPoruka" Margin="0,8,0,0" Foreground="DarkRed"/>
        </StackPanel>
    </Grid>
</Window>